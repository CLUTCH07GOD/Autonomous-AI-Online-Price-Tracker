MYSQL_DATABASE=price_intelligence
MYSQL_ROOT_PASSWORD=pass123
# For Docker Compose backend -> MySQL container:
DATABASE_URL=mysql+pymysql://root:pass123@db:3306/price_intelligence
# For running backend directly against your local MySQL Workbench server, use:
# DATABASE_URL=mysql+pymysql://root:pass123@127.0.0.1:3306/price_intelligence
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@price-intelligence.local
TELEGRAM_BOT_TOKEN=
SCRAPER_TIMEOUT_MS=35000
VITE_API_BASE_URL=http://localhost:8000/api
REDIS_URL=redis://redis:6379/0
